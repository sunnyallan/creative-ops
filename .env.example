# --- AI / Generation ---
GEMINI_API_KEY=
FAL_KEY=

# --- Brand safety ---
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# --- Supabase (auth, postgres, storage) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Use the SESSION POOLER URL (aws-*.pooler.supabase.com:5432) — the direct db.* host is IPv6-only.
SUPABASE_DB_URL=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=tenant-assets

# --- Celery / Redis ---
REDIS_URL=redis://redis:6379/0

# --- Frontend (Vercel) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Penpot (v3.0 custom templates — see docs/penpot-railway-setup.md) ---
PENPOT_BASE_URL=
PENPOT_ACCESS_TOKEN=

# --- Stubbed platform integrations (Phase 3) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
# v4.0 Phase C — Meta Marketing API
META_REDIRECT_URI=https://creative-ops-production.up.railway.app/connections/meta/callback
META_API_VERSION=v21.0
META_USE_SANDBOX=true
# Fernet key for encrypting stored OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
API_BASE_URL=https://creative-ops-production.up.railway.app

# --- Access control ---
# Comma-separated allowlist. Empty = allow all (dev default).
# Prod: lock to specific emails.
ALLOWED_EMAILS=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
